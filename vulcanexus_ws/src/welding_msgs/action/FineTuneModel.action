# Submit current session data for ML model fine-tuning.
# Triggered by the "Fine-tune" button in the ROBIN dashboard.
# ros4hri: maps to ml_skills/action/FineTuneModel

# ── Goal ──────────────────────────────────────────────────────────────────
string process_id    # NGSI-LD process entity ID, e.g. "ros_bridge"
string dataset_tag   # label for this data batch, e.g. "operator_submit"

---

# ── Result ─────────────────────────────────────────────────────────────────
bool   success
string message
int32  samples_submitted   # number of data points queued for training

---

# ── Feedback ───────────────────────────────────────────────────────────────
float32 progress_pct   # 0.0 → 100.0
string  phase          # "COLLECTING" | "UPLOADING" | "QUEUED"
